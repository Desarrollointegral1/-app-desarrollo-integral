"use client";

import { useEffect } from "react";

interface NavDrawerProps {
  isOpen: boolean;
  onClose: () => void;
}

export function NavDrawer({ isOpen, onClose }: NavDrawerProps) {
  useEffect(() => {
    if (isOpen) {
      document.body.style.overflow = "hidden";
    } else {
      document.body.style.overflow = "";
    }
    return () => {
      document.body.style.overflow = "";
    };
  }, [isOpen]);

  return (
    <>
      {/* Backdrop */}
      <div
        className="nav-drawer-backdrop"
        onClick={onClose}
        style={{
          opacity: isOpen ? 1 : 0,
          pointerEvents: isOpen ? "auto" : "none",
          transition: "opacity 300ms ease",
        }}
      />

      {/* Drawer */}
      <div
        className="nav-drawer"
        style={{
          transform: isOpen ? "translateX(0)" : "translateX(100%)",
          transition: "transform 300ms cubic-bezier(0.23, 1, 0.32, 1)",
        }}
      >
        <button className="nav-drawer-close" onClick={onClose} aria-label="Close menu">
          ✕
        </button>

        <nav className="nav-drawer-content">
          <a href="#identidad" onClick={onClose} className="nav-drawer-link">
            Identidad
          </a>
          <a href="#metodo" onClick={onClose} className="nav-drawer-link">
            Método
          </a>
          <a href="#plataforma" onClick={onClose} className="nav-drawer-link">
            Plataforma
          </a>
          <a href="#form" onClick={onClose} className="nav-drawer-link nav-drawer-link-primary">
            Contacto
          </a>
        </nav>
      </div>
    </>
  );
}
